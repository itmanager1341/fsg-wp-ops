# fsg-wp-ops — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.
# direnv loads .env automatically when you cd into this folder.

# ── WP Engine API ─────────────────────────────────────────────────────────────
# Generate at: WP Engine portal → User → API Access
# WPE_CREDS = base64("user_id:password") — generate with:
#   echo -n "USER_ID:PASSWORD" | base64
WPE_USER_ID=
WPE_PASSWORD=
WPE_CREDS=

# ── WP Engine Install IDs ─────────────────────────────────────────────────────
# Retrieve with: scripts/wpe-api.sh installs
# Needed for GitHub Actions secrets and API calls
WPE_INSTALL_ID_FSI_PROD=
WPE_INSTALL_ID_FSI_STG=
WPE_INSTALL_ID_FSI_DEV=
WPE_INSTALL_ID_MP_PROD=
WPE_INSTALL_ID_AMAA_PROD=

# ── GitHub Actions secrets mirror ────────────────────────────────────────────
# These same values go in GitHub repo Secrets for each site repo.
# Do not store the SSH private key here — register it in WPE portal only.
# WPE_SSH_PRIVATE_KEY is set in GitHub Secrets, not here.
