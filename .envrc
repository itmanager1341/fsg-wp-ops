# direnv config for fsg-wp-ops
# Loads .env into shell when you cd into this folder.
# Requires direnv installed and hooked into your shell (you already have this).

# Load .env if it exists
if [ -f .env ]; then
  dotenv .env
fi

# Repo-level env vars (safe to commit)
export FSG_WP_OPS_ROOT="$PWD"
export WPE_API_BASE="https://api.wpengineapi.com/v1"
