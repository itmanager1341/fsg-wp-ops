        "html": "<div class=\"fsi-grid-3\" style=\"margin-bottom:48px;\">\n  <div style=\"text-align:center; background:#f7f7f5; border:1px solid #e0e0dc; border-radius:4px; padding:24px 16px;\">\n    <h4 style=\"margin-bottom:8px;\">When</h4>\n    <p style=\"font-size:16px; font-weight:600; color:#1f365c;\">May 20-21, 2026</p>\n    <p style=\"margin-top:8px;\"><a href=\"https://fivestarglobal.swoogo.com/velocity2026/agenda\" style=\"font-size:14px;\">View Full Agenda &rarr;</a></p>\n  </div>\n  <div style=\"text-align:center; background:#f7f7f5; border:1px solid #e0e0dc; border-radius:4px; padding:24px 16px;\">\n    <h4 style=\"margin-bottom:8px;\">Where</h4>\n    <p style=\"font-size:16px; font-weight:600; color:#1f365c;\">The Westin</p>\n    <p style=\"color:#666;\">New Orleans, Louisiana</p>\n    <p style=\"margin-top:8px;\"><a href=\"https://fivestarglobal.swoogo.com/velocity2026/venue\" style=\"font-size:14px;\">Venue Details &rarr;</a></p>\n  </div>\n  <div style=\"text-align:center; background:#f7f7f5; border:1px solid #e0e0dc; border-radius:4px; padding:24px 16px;\">\n    <h4 style=\"margin-bottom:8px;\">Questions</h4>\n    <p style=\"color:#666;\">Contact the events team</p>\n    <p style=\"margin-top:8px;\"><a href=\"mailto:force@thefivestar.com\" style=\"font-size:14px;\">force@thefivestar.com</a></p>\n  </div>\n</div>"
