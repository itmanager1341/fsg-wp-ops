      "settings": {
        "html": "<div style=\"max-width:1100px; margin:0 auto;\">\n  <div style=\"display:grid; grid-template-columns:repeat(3, 1fr); gap:24px;\">\n\n    <!-- FORCE -->\n    <div style=\"background:#fff; border:1px solid #e0e0dc; border-radius:6px; padding:28px 24px; display:flex; flex-direction:column;\">\n      <div style=\"background:#f7f7f5; border-radius:4px; padding:20px; margin:-8px -8px 20px; min-height:100px; display:flex; align-items:center; justify-content:center;\">\n        <img src=\"/wp-content/uploads/2026/04/FSI-Brand-logo_FORCE_COLOR-300x78.png\" alt=\"FORCE — Federation of REO Certified Experts\" width=\"200\" height=\"52\" loading=\"lazy\" style=\"max-width:100%; height:auto;\" />\n      </div>\n      <h3 style=\"font-size:24px; font-weight:700; color:#1f365c; margin:0 0 4px;\">FORCE</h3>\n      <p style=\"color:#666; font-size:14px; margin:0 0 16px;\">Real Estate Professionals</p>\n      <p style=\"color:#444; font-size:14px; line-height:1.6; margin:0 0 20px; flex:1;\">The credentialing and membership body for agents, brokers, and REO specialists in institutional real estate markets.</p>\n      <div style=\"display:flex; gap:8px; flex-wrap:wrap;\">\n        <a href=\"/communities/real-estate-professionals/\" style=\"flex:1; min-width:140px; text-align:center; background:#fff; color:#1f365c; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Community</a>\n        <a href=\"https://fivestarforce.com\" target=\"_blank\" rel=\"noopener\" style=\"flex:1; min-width:140px; text-align:center; background:#1f365c; color:#fff; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Member Portal</a>\n      </div>\n    </div>\n\n    <!-- LEGAL LEAGUE -->\n    <div style=\"background:#fff; border:1px solid #e0e0dc; border-radius:6px; padding:28px 24px; display:flex; flex-direction:column;\">\n      <div style=\"background:#f7f7f5; border-radius:4px; padding:20px; margin:-8px -8px 20px; min-height:100px; display:flex; align-items:center; justify-content:center;\">\n        <img src=\"/wp-content/uploads/2026/04/FSI-Brand-logo_LL_COLOR-300x78.png\" alt=\"Legal League\" width=\"200\" height=\"52\" loading=\"lazy\" style=\"max-width:100%; height:auto;\" />\n      </div>\n      <h3 style=\"font-size:24px; font-weight:700; color:#1f365c; margin:0 0 4px;\">Legal League</h3>\n      <p style=\"color:#666; font-size:14px; margin:0 0 16px;\">Financial Services Attorneys</p>\n      <p style=\"color:#444; font-size:14px; line-height:1.6; margin:0 0 20px; flex:1;\">Firm membership for foreclosure, bankruptcy, and mortgage servicing law practices. Governed by an Advisory Council.</p>\n      <div style=\"display:flex; gap:8px; flex-wrap:wrap;\">\n        <a href=\"/communities/\" style=\"flex:1; min-width:140px; text-align:center; background:#fff; color:#1f365c; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Community</a>\n        <a href=\"https://www.legalleague100.com\" target=\"_blank\" rel=\"noopener\" style=\"flex:1; min-width:140px; text-align:center; background:#1f365c; color:#fff; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Member Portal</a>\n      </div>\n    </div>\n\n    <!-- NMSA -->\n    <div style=\"background:#fff; border:1px solid #e0e0dc; border-radius:6px; padding:28px 24px; display:flex; flex-direction:column;\">\n      <div style=\"background:#f7f7f5; border-radius:4px; padding:20px; margin:-8px -8px 20px; min-height:100px; display:flex; align-items:center; justify-content:center;\">\n        <img src=\"/wp-content/uploads/2026/04/FSI-Brand-logo_NMSA_COLOR-300x83.png\" alt=\"NMSA — National Mortgage Servicing Association\" width=\"200\" height=\"55\" loading=\"lazy\" style=\"max-width:100%; height:auto;\" />\n      </div>\n      <h3 style=\"font-size:24px; font-weight:700; color:#1f365c; margin:0 0 4px;\">NMSA</h3>\n      <p style=\"color:#666; font-size:14px; margin:0 0 16px;\">Mortgage Finance &mdash; C-Suite</p>\n      <p style=\"color:#444; font-size:14px; line-height:1.6; margin:0 0 20px; flex:1;\">A curated peer forum for C-suite executives at mortgage servicers, subservicers, and GSE-adjacent institutions.</p>\n      <div style=\"display:flex; gap:8px; flex-wrap:wrap;\">\n        <a href=\"/communities/\" style=\"flex:1; min-width:140px; text-align:center; background:#fff; color:#1f365c; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Community</a>\n        <a href=\"https://nationalmortgageservicingassociation.com\" target=\"_blank\" rel=\"noopener\" style=\"flex:1; min-width:140px; text-align:center; background:#1f365c; color:#fff; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Member Portal</a>\n      </div>\n    </div>\n\n    <!-- MSEA -->\n    <div style=\"background:#fff; border:1px solid #e0e0dc; border-radius:6px; padding:28px 24px; display:flex; flex-direction:column;\">\n      <div style=\"background:#f7f7f5; border-radius:4px; padding:20px; margin:-8px -8px 20px; min-height:100px; display:flex; align-items:center; justify-content:center;\">\n        <img src=\"/wp-content/uploads/2026/04/FSI-Brand-logo_MSEA_COLOR-300x83.png\" alt=\"MSEA — Mortgage Servicing Executive Alliance\" width=\"200\" height=\"55\" loading=\"lazy\" style=\"max-width:100%; height:auto;\" />\n      </div>\n      <h3 style=\"font-size:24px; font-weight:700; color:#1f365c; margin:0 0 4px;\">MSEA</h3>\n      <p style=\"color:#666; font-size:14px; margin:0 0 16px;\">Mortgage Finance &mdash; Senior Management</p>\n      <p style=\"color:#444; font-size:14px; line-height:1.6; margin:0 0 20px; flex:1;\">The NMSA pipeline for rising mortgage servicing leaders. A curated community for senior professionals in mortgage finance.</p>\n      <div style=\"display:flex; gap:8px; flex-wrap:wrap;\">\n        <a href=\"/communities/\" style=\"flex:1; min-width:140px; text-align:center; background:#fff; color:#1f365c; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Community</a>\n        <a href=\"https://themsea.com\" target=\"_blank\" rel=\"noopener\" style=\"flex:1; min-width:140px; text-align:center; background:#1f365c; color:#fff; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Member Portal</a>\n      </div>\n    </div>\n\n    <!-- PPEF -->\n    <div style=\"background:#fff; border:1px solid #e0e0dc; border-radius:6px; padding:28px 24px; display:flex; flex-direction:column;\">\n      <div style=\"background:#f7f7f5; border-radius:4px; padding:20px; margin:-8px -8px 20px; min-height:100px; display:flex; align-items:center; justify-content:center;\">\n        <img src=\"/wp-content/uploads/2026/04/FSI-Brand-logo_PPEF_COLOR-300x83.png\" alt=\"PPEF — Property Preservation Executive Forum\" width=\"200\" height=\"55\" loading=\"lazy\" style=\"max-width:100%; height:auto;\" />\n      </div>\n      <h3 style=\"font-size:24px; font-weight:700; color:#1f365c; margin:0 0 4px;\">PPEF</h3>\n      <p style=\"color:#666; font-size:14px; margin:0 0 16px;\">Property Preservation &amp; Services</p>\n      <p style=\"color:#444; font-size:14px; line-height:1.6; margin:0 0 20px; flex:1;\">Membership organization for national property preservation companies. Servicers and GSEs participate as institutional partners.</p>\n      <div style=\"display:flex; gap:8px; flex-wrap:wrap;\">\n        <a href=\"/communities/\" style=\"flex:1; min-width:140px; text-align:center; background:#fff; color:#1f365c; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Community</a>\n        <a href=\"https://propertypresforum.com\" target=\"_blank\" rel=\"noopener\" style=\"flex:1; min-width:140px; text-align:center; background:#1f365c; color:#fff; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Member Portal</a>\n      </div>\n    </div>\n\n    <!-- AMDC (single button) -->\n    <div style=\"background:#fff; border:1px solid #e0e0dc; border-radius:6px; padding:28px 24px; display:flex; flex-direction:column;\">\n      <div style=\"background:#f7f7f5; border-radius:4px; padding:20px; margin:-8px -8px 20px; min-height:100px; display:flex; align-items:center; justify-content:center;\">\n        <img src=\"/wp-content/uploads/2026/04/FSI-Brand-logo_AMDC_COLOR-300x83.png\" alt=\"AMDC — American Mortgage Diversity Council\" width=\"200\" height=\"55\" loading=\"lazy\" style=\"max-width:100%; height:auto;\" />\n      </div>\n      <h3 style=\"font-size:24px; font-weight:700; color:#1f365c; margin:0 0 4px;\">AMDC</h3>\n      <p style=\"color:#666; font-size:14px; margin:0 0 16px;\">All Communities &mdash; Diversity Initiative</p>\n      <p style=\"color:#444; font-size:14px; line-height:1.6; margin:0 0 20px; flex:1;\">A horizontal diversity and inclusion initiative spanning all FSI professional communities, events, and channels.</p>\n      <div>\n        <a href=\"https://mortgagediversitycouncil.com\" target=\"_blank\" rel=\"noopener\" style=\"display:block; text-align:center; background:#1f365c; color:#fff; border:2px solid #1f365c; border-radius:4px; padding:10px 16px; font-weight:700; font-size:13px; text-decoration:none; text-transform:uppercase;\">Member Portal</a>\n      </div>\n    </div>\n\n  </div>\n</div>"
      },
